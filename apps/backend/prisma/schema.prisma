generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model KnowledgeDocument {
  id               String                      @id @default(uuid()) @db.Uuid
  title            String
  sourceType       KnowledgeDocumentSourceType @default(other)
  status           KnowledgeDocumentStatus     @default(uploaded)
  originalFileName String?                     @map("original_file_name")
  mimeType         String?                     @map("mime_type")
  size             Int?
  storagePath      String?                     @map("storage_path")
  authority        String?
  jurisdiction     String?
  publishDate      DateTime?                   @map("publish_date")
  effectiveDate    DateTime?                   @map("effective_date")
  version          String?
  tags             String[]                    @default([])
  metadata         Json                        @default("{}")
  chunks           KnowledgeDocumentChunk[]
  knowledgeBases   KnowledgeBaseDocument[]
  indexJobs        IndexJob[]
  createdAt        DateTime                    @default(now()) @map("created_at")
  updatedAt        DateTime                    @updatedAt @map("updated_at")

  @@map("knowledge_documents")
}

model KnowledgeDocumentChunk {
  id          String                       @id @default(uuid()) @db.Uuid
  documentId  String                       @map("document_id") @db.Uuid
  document    KnowledgeDocument            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content     String
  sectionPath String?                      @map("section_path")
  articleNo   String?                      @map("article_no")
  chunkIndex  Int                          @map("chunk_index")
  embedding   Unsupported("vector(1024)")?
  metadata    Json                         @default("{}")
  createdAt   DateTime                     @default(now()) @map("created_at")

  @@index([documentId])
  @@index([articleNo])
  @@map("knowledge_document_chunks")
}

enum KnowledgeDocumentStatus {
  uploaded
  parsing
  parsed
  indexing
  indexed
  failed
}

enum KnowledgeDocumentSourceType {
  law
  judicial_interpretation
  case
  contract
  internal
  other
}

model IndexJob {
  id                String             @id @default(uuid()) @db.Uuid
  documentId        String?            @map("document_id") @db.Uuid
  document          KnowledgeDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  parentJobId       String?            @map("parent_job_id") @db.Uuid
  parentJob         IndexJob?          @relation("IndexJobHierarchy", fields: [parentJobId], references: [id], onDelete: SetNull)
  childJobs         IndexJob[]         @relation("IndexJobHierarchy")
  attemptOfJobId    String?            @map("attempt_of_job_id") @db.Uuid
  attemptOfJob      IndexJob?          @relation("IndexJobAttempts", fields: [attemptOfJobId], references: [id], onDelete: SetNull)
  retryAttempts     IndexJob[]         @relation("IndexJobAttempts")
  queueJobId        String?            @unique @map("queue_job_id")
  cancelRequestedAt DateTime?          @map("cancel_requested_at")
  type              IndexJobType
  status            IndexJobStatus     @default(pending)
  progress          Int                @default(0)
  currentStep       String?            @map("current_step")
  errorMessage      String?            @map("error_message")
  retryCount        Int                @default(0) @map("retry_count")
  result            Json               @default("{}")
  startedAt         DateTime?          @map("started_at")
  finishedAt        DateTime?          @map("finished_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([documentId])
  @@index([parentJobId])
  @@index([attemptOfJobId])
  @@index([status])
  @@index([type])
  @@map("index_jobs")
}

model EvaluationCase {
  id                  String          @id @default(uuid()) @db.Uuid
  query               String
  expectedDocumentIds String[]        @default([]) @map("expected_document_ids")
  expectedChunkIds    String[]        @default([]) @map("expected_chunk_ids")
  expectedArticleRefs String[]        @default([]) @map("expected_article_refs")
  expectedKeywords    String[]        @default([]) @map("expected_keywords")
  difficulty          String?
  tags                String[]        @default([])
  runs                EvaluationRun[]
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@map("evaluation_cases")
}

model EvaluationRun {
  id             String          @id @default(uuid()) @db.Uuid
  caseId         String?         @map("case_id") @db.Uuid
  evaluationCase EvaluationCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  query          String
  topK           Int             @default(20) @map("top_k")
  searchParams   Json            @default("{}") @map("search_params")
  resultSnapshot Json            @default("[]") @map("result_snapshot")
  metrics        Json            @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at")

  @@index([caseId])
  @@map("evaluation_runs")
}

model KnowledgeBase {
  id          String                  @id @default(uuid()) @db.Uuid
  name        String
  code        String                  @unique
  description String?
  category    String?
  status      KnowledgeBaseStatus     @default(active)
  documents   KnowledgeBaseDocument[]
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  @@map("knowledge_bases")
}

model KnowledgeBaseDocument {
  id              String            @id @default(uuid()) @db.Uuid
  knowledgeBaseId String            @map("knowledge_base_id") @db.Uuid
  documentId      String            @map("document_id") @db.Uuid
  knowledgeBase   KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now()) @map("created_at")

  @@unique([knowledgeBaseId, documentId])
  @@index([documentId])
  @@map("knowledge_base_documents")
}

model QaTrace {
  id             String   @id @default(uuid()) @db.Uuid
  question       String
  answer         String
  searchParams   Json     @default("{}") @map("search_params")
  sourceSnapshot Json     @default("[]") @map("source_snapshot")
  citations      Json     @default("[]")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("qa_traces")
}

model AgentSession {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String?            @map("user_id") @db.Uuid
  title            String?
  agentType        AgentType          @default(legal_qa) @map("agent_type")
  status           AgentSessionStatus @default(active)
  knowledgeBaseIds String[]           @default([]) @map("knowledge_base_ids")
  metadata         Json               @default("{}")
  messages         AgentMessage[]
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@index([userId])
  @@index([agentType])
  @@index([status])
  @@map("agent_sessions")
}

model AgentMessage {
  id        String             @id @default(uuid()) @db.Uuid
  sessionId String             @map("session_id") @db.Uuid
  session   AgentSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      AgentMessageRole
  content   String
  status    AgentMessageStatus @default(completed)
  citations Json               @default("[]")
  toolCalls Json               @default("[]") @map("tool_calls")
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([role])
  @@index([status])
  @@map("agent_messages")
}

model AgentMemory {
  id        String                       @id @default(uuid()) @db.Uuid
  userId    String?                      @map("user_id") @db.Uuid
  sessionId String?                      @map("session_id") @db.Uuid
  type      AgentMemoryType
  content   String
  summary   String?
  embedding Unsupported("vector(1024)")?
  metadata  Json                         @default("{}")
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")

  @@index([userId])
  @@index([sessionId])
  @@index([type])
  @@map("agent_memories")
}

model AgentTrace {
  id             String   @id @default(uuid()) @db.Uuid
  sessionId      String?  @map("session_id") @db.Uuid
  messageId      String?  @map("message_id") @db.Uuid
  agentType      String   @map("agent_type")
  input          Json     @default("{}")
  output         Json     @default("{}")
  toolCalls      Json     @default("[]") @map("tool_calls")
  promptSnapshot Json     @default("{}") @map("prompt_snapshot")
  modelInfo      Json     @default("{}") @map("model_info")
  error          String?
  latencyMs      Int?     @map("latency_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([messageId])
  @@index([agentType])
  @@map("agent_traces")
}

enum AgentType {
  legal_qa
  legal_research
  document_review
}

enum AgentSessionStatus {
  active
  archived
}

enum AgentMessageRole {
  system
  user
  assistant
  tool
}

enum AgentMessageStatus {
  pending
  running
  completed
  failed
}

enum AgentMemoryType {
  short_summary
  long_term_fact
  user_preference
  case_context
}

enum IndexJobType {
  parse_document
  rebuild_document_index
  rebuild_all_indexes
  delete_document_index
}

enum IndexJobStatus {
  pending
  running
  succeeded
  failed
  canceled
}

enum KnowledgeBaseStatus {
  active
  archived
}

// ==================== RBAC Models ====================

model User {
  id        String     @id @default(uuid()) @db.Uuid
  username  String     @unique
  password  String
  realName  String?    @map("real_name")
  homePath  String?    @map("home_path")
  avatar    String?
  status    UserStatus @default(active)
  deptId    String?    @map("dept_id") @db.Uuid
  dept      Dept?      @relation(fields: [deptId], references: [id])
  roles     UserRole[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  description String?
  status      RoleStatus @default(active)
  menus       RoleMenu[]
  users       UserRole[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("roles")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Menu {
  id        String     @id @default(uuid()) @db.Uuid
  parentId  String?    @map("parent_id") @db.Uuid
  parent    Menu?      @relation("MenuTree", fields: [parentId], references: [id])
  children  Menu[]     @relation("MenuTree")
  name      String     @unique
  path      String
  component String?
  icon      String?
  type      MenuType
  status    MenuStatus @default(active)
  orderNo   Int        @default(0) @map("order_no")
  meta      Json       @default("{}")
  roles     RoleMenu[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("menus")
}

model RoleMenu {
  id     String @id @default(uuid()) @db.Uuid
  roleId String @map("role_id") @db.Uuid
  menuId String @map("menu_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@map("role_menus")
}

model Dept {
  id        String     @id @default(uuid()) @db.Uuid
  parentId  String?    @map("parent_id") @db.Uuid
  parent    Dept?      @relation("DeptTree", fields: [parentId], references: [id])
  children  Dept[]     @relation("DeptTree")
  name      String
  status    DeptStatus @default(active)
  remark    String?
  users     User[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("depts")
}

enum UserStatus {
  active
  inactive
}

enum RoleStatus {
  active
  inactive
}

enum MenuStatus {
  active
  inactive
}

enum MenuType {
  catalog
  menu
  button
}

enum DeptStatus {
  active
  inactive
}
