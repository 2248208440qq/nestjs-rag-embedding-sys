APP_NAME=rag-embedding
API_VERSION=1.0.0
NODE_ENV=development
PORT=3000
BACKEND_PORT=3000
DATABASE_URL=postgresql://rag:rag_password@127.0.0.1:15432/rag_embedding?schema=public
EMBEDDING_BASE_URL=http://localhost:8000/v1
EMBEDDING_MODEL=qwen3-embedding
EMBEDDING_BATCH_SIZE=16
LLM_ENABLED=false
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=your-deepseek-api-key
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_MS=60000
REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_DB=0
LOG_LEVEL=debug
LOG_DIR=logs
LOG_TO_FILE=false
LOG_SERVICE_NAME=backend
