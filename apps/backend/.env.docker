APP_NAME=rag-embedding
API_VERSION=1.0.0
NODE_ENV=production
PORT=3000
BACKEND_PORT=3000
DATABASE_URL=postgresql://rag:rag_password@postgres:5432/rag_embedding?schema=public
EMBEDDING_BASE_URL=http://embedding:8000/v1
EMBEDDING_MODEL=qwen3-embedding
EMBEDDING_BATCH_SIZE=16
LLM_ENABLED=false
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_MS=60000
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
LOG_LEVEL=info
LOG_DIR=logs
LOG_TO_FILE=true
LOG_SERVICE_NAME=backend
