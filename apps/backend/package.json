{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "prisma": "node ../../scripts/with-env-docker.cjs prisma",
    "db:generate": "node ../../scripts/with-env-docker.cjs prisma generate",
    "db:migrate": "node ../../scripts/with-env-docker.cjs prisma migrate deploy",
    "prisma:generate": "node ../../scripts/with-env-docker.cjs prisma generate",
    "prisma:migrate": "node ../../scripts/with-env-docker.cjs prisma migrate dev",
    "prisma:push": "node ../../scripts/with-env-docker.cjs prisma db push",
    "prisma:studio": "node ../../scripts/with-env-docker.cjs prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.11",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.11",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^6.19.0",
    "@repo/shared-backend": "workspace:*",
    "@repo/shared-types": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.8.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.11",
    "@repo/eslint-config": "workspace:*",
    "@repo/jest-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "jszip": "^3.10.1",
    "prisma": "^6.19.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.5.4"
  }
