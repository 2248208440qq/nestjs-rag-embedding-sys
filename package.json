{
  "name": "rag-embedding",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "pnpm --dir apps/frontend --filter @vben/admin dev",
    "dev:backend": "turbo run dev --filter=backend",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:api": "node scripts/vite-test/run.mjs",
    "test:api:local": "node scripts/vite-test/local-run.mjs",
    "test:docs": "node scripts/vite-test/run.mjs --docs-only",
    "docker:test": "node scripts/vite-test/local-run.mjs",
    "lint": "turbo run lint",
    "docker:up": "docker compose -p rag-embedding-knowledge up -d",
    "docker:down": "docker compose -p rag-embedding-knowledge down",
    "docker:logs": "docker compose -p rag-embedding-knowledge logs -f postgres redis embedding",
    "backend:db:push": "pnpm --filter backend prisma:push",
    "backend:db:seed": "pnpm --filter backend prisma:seed",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:generate": "pnpm --filter backend db:generate",
    "dev:backend:local": "turbo run dev --filter=backend",
    "dev:backend:docker": "pnpm docker:up && pnpm backend:db:push && pnpm --filter backend dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "prettier": "^3.2.5",
    "turbo": "^2.9.18"
  },
  "packageManager": "pnpm@8.15.5",
  "engines": {
    "node": ">=18"
  }
}
